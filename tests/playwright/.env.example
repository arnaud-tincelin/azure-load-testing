# Azure App Testing Demo — Environment Variables
# Copy to .env and fill in values after running `azd up`.

# Albums API URL (set automatically by azd; override for local dev)
SERVICE_ALBUMS_API_ENDPOINT_URL=http://localhost:5080

# Albums Frontend URL (set automatically by azd)
# SERVICE_ALBUMS_FRONTEND_ENDPOINT_URL=https://<frontend-app>.azurecontainerapps.io

# Azure Playwright Testing — workspace endpoint (set by postprovision hook)
# PLAYWRIGHT_SERVICE_URL=wss://<region>.api.playwright.microsoft.com/accounts/<workspace-id>/browsers

# Azure Load Testing — resource details (set by azd env)
# AZURE_LOAD_TESTING_RESOURCE_GROUP=
# AZURE_LOAD_TESTING_RESOURCE_NAME=
